# Server
HTTP_PORT=5000

# Firebase (optional)
FIREBASE_CREDENTIALS_FILE=config/firebase-service-account.json
FIREBASE_PROJECT_ID=myslotmate-25994

# PostgreSQL – point to EC2 (Docker runs there)
# postgresql://postgres:YOUR_PASSWORD@YOUR_EC2_PUBLIC_IP:5432/myslotmate
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_EC2_PUBLIC_IP:5432/myslotmate
