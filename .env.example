# ── Server ────────────────────────────────────
HTTP_PORT=8080

# ── Firebase ──────────────────────────────────
FIREBASE_CREDENTIALS_FILE=config/firebase-service-account.json
FIREBASE_PROJECT_ID=myslotmate-25994

# ── AWS S3 (File Uploads) ────────────────────
AWS_S3_BUCKET=myslotmate-uploads
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Database (PostgreSQL) ─────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/myslotmate

# ── Setu OKYC (Aadhar Verification) ──────────
# Get these from https://bridge.setu.co → Products → OKYC
SETU_BASE_URL=https://uat.setu.co        # Use https://prod.setu.co for production
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=

# ── Razorpay Payments (Wallet Top-Ups) ───────
# Get these from https://dashboard.razorpay.com → Settings → API Keys / Webhooks
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PAYMENT_WEBHOOK_SECRET=         # Payment webhook secret (preferred)
RAZORPAY_WEBHOOK_SECRET=                 # Legacy/shared webhook secret fallback

# ── Cashfree Payouts ─────────────────────────
# Get these from https://merchant.cashfree.com → Payouts API / Webhooks
CASHFREE_BASE_URL=https://payout-api.cashfree.com
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_WEBHOOK_SECRET=
CASHFREE_API_VERSION=2024-01-01

# ── Migrations (optional) ────────────────────
# MIGRATIONS_DIR=migrations              # Override path to SQL migration files
